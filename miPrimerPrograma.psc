Algoritmo miPrimerPrograma
    Definir x Como entero
	Imprimir "ingrese el numero a evaluar"
	leer x 
	mientras x>0 Hacer
		si x MOD 2 == 0 entonces 
			imprimir "el numero es par"
		SiNo
			imprimir"el numero es impar"
		FinSi
		imprimir "ingrese el numero a evaluar"
		leer x 
	FinMientras
	imprimir "el numero ingresado fue menor o igual a cero"
FinAlgoritmo